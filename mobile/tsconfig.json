{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"]
		},
		"types": ["react", "react-native", "expo-router/types"]
	},
	"include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}

APP_NAME=Qora Qarg'a
DEBUG=false
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:5173

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/messenger
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

JWT_SECRET_KEY=replace_with_secure_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

MESSAGE_RATE_LIMIT_PER_SECOND=8
MESSAGE_QUEUE_NAME=messaging.events
NOTIFICATION_QUEUE_NAME=notification.events
ANALYTICS_QUEUE_NAME=analytics.events
WORKER_RETRY_LIMIT=5

S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=messenger-files
S3_PRESIGN_EXPIRE_SECONDS=900
LOCAL_MEDIA_DIR=media
LOCAL_MEDIA_BASE_URL=

PRESENCE_SESSION_TTL_SECONDS=120
PRESENCE_TYPING_TTL_SECONDS=1
PRESENCE_CLEANUP_INTERVAL_SECONDS=20
CONVERSATION_CACHE_TTL_SECONDS=600
CONVERSATION_RECENT_MESSAGES_LIMIT=200
WEBSOCKET_INSTANCE_ID=ws-1
